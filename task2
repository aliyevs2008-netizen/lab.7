<!-- HTML Hiss…ôsi -->
<input type="number" id="num1" placeholder="Birinci …ôd…ôd">
<input type="number" id="num2" placeholder="ńįkinci …ôd…ôd">

<button onclick="hesabla('+')">+</button>
<button onclick="hesabla('-')">-</button>

<p>N…ôtic…ô: <span id="netic…ô">0</span></p>

<script>
// JavaScript Hiss…ôsi
function hesabla(emeliyyat) {
    // ńįnputlardan d…ôy…ôrl…ôri alńĪrńĪq v…ô …ôd…ôd…ô (Number) √ßeviririk
    const a = Number(document.getElementById('num1').value);
    const b = Number(document.getElementById('num2').value);
    let netice = 0;

    // Klikl…ôn…ôn d√ľym…ôy…ô g√∂r…ô …ôm…ôliyyatńĪ t…ôyin edirik
    if (emeliyyat === '+') {
        netice = a + b;
    } else if (emeliyyat === '-') {
        netice = a - b;
    }

    // N…ôtic…ôni ekrana yazdńĪrńĪrńĪq
    document.getElementById('netic…ô').innerText = netice;
}
</script>
