css


* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background-color: #f0f2f5;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

.app-container {
    background-color: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    text-align: center;
    width: 100%;
    max-width: 400px;
}

h2 {
    color: #1a1a1a;
    margin-bottom: 20px;
    font-size: 22px;
}

.input-group {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
}

input {
    flex: 1;
    padding: 12px;
    border: 2px solid #e4e6eb;
    border-radius: 8px;
    font-size: 15px;
    outline: none;
    transition: border-color 0.3s;
}

input:focus {
    border-color: #007bff;
}

button {
    padding: 12px 20px;
    background-color: #007bff;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 0.2s;
}

button:hover {
    background-color: #0056b3;
}

#result-text {
    font-size: 18px;
    color: #333;
    font-weight: 500;
    word-wrap: break-word; /* Uzun mətnlərin qutudan kənara çıxmaması üçün */
    min-height: 27px;      /* Mətn yox ikən yerinin boş qalmamsı üçün */
}



js


document.addEventListener("DOMContentLoaded", function () {
    // Elementləri ID-lərinə görə seçirik
    const userInput = document.getElementById("user-input");
    const showBtn = document.getElementById("show-btn");
    const resultText = document.getElementById("result-text");

    // Düyməyə klikləmə hadisəsini (click event) qeydə alırıq
    showBtn.addEventListener("click", function () {
        // Input sahəsindəki mətni götürürük (kənarlardakı boşluqları trim() ilə silirik)
        const inputText = userInput.value.trim();

        // Əgər istifadəçi heç bir şey yazmayıbsa xəbərdarlıq edirik
        if (inputText === "") {
            resultText.style.color = "red";
            resultText.textContent = "Zəhmət olmasa, boş buraxmayın!";
        } else {
            // Mətn yazılıbsa rəngini normal edib p teqinə mətni ötürürük
            resultText.style.color = "#333";
            resultText.textContent = inputText;
            
            // İstəyə bağlı: Mətn göndərildikdən sonra input sahəsini təmizləmək üçün:
            // userInput.value = "";
        }
    });
});
